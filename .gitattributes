# Enforce LF for text files in this repo on all platforms
* text=auto

# Keep JSON files normalized with LF line endings
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.csv text eol=lf
*.sh text eol=lf
